{
  "$schema": "preset-tokens-v1",
  "preset": "<folder-name>",
  "color": {
    "primitive": {
      "gray": { "50": "#FAFAFA", "100": "#F4F4F5", "200": "#E4E4E7", "300": "#D4D4D8", "400": "#A1A1AA", "500": "#71717A", "600": "#52525B", "700": "#3F3F46", "800": "#27272A", "900": "#18181B" }
    },
    "semantic": {
      "text-primary": "{color.primitive.gray.900}",
      "text-secondary": "{color.primitive.gray.600}",
      "surface-default": "#FFFFFF",
      "border-default": "{color.primitive.gray.200}",
      "accent-brand": "<#brand>",
      "state-error": "<#error>",
      "state-success": "<#success>",
      "state-warning": "<#warning>",
      "state-info": "<#info>"
    }
  },
  "spacing": {
    "scale": "4pt",
    "space-0": 0,
    "space-1": 4, "space-2": 8, "space-3": 12, "space-4": 16,
    "space-5": 24, "space-6": 32, "space-7": 48, "space-8": 64
  },
  "radius": {
    "none": 0, "sm": 4, "md": 8, "lg": 12, "full": 9999
  },
  "elevation": {
    "none": "none",
    "sm": "0 1px 2px rgba(0,0,0,0.06)",
    "md": "0 3px 8px rgba(0,0,0,0.08)",
    "lg": "0 8px 24px rgba(0,0,0,0.10)",
    "xl": "0 16px 48px rgba(0,0,0,0.12)"
  },
  "motion": {
    "instant": "0ms", "fast": "150ms", "default": "250ms", "slow": "400ms"
  },
  "z-index": {
    "base": 0, "dropdown": 100, "sticky": 200, "modal": 1000, "toast": 2000
  }
}
