{
  "$schema": "preset-tokens-v1",
  "preset": "default",
  "_provenance": {
    "anchor_colors": "Operator-provided: #1c5d99 primary, #639fab secondary, #bbcde5 disabled, #222222 text, #FFFFFF background. Full 50-900 scales derived around these anchors.",
    "brand_scale": "Derived from #1c5d99 via standard tint/shade progression. Verify against deployed contrast at small sizes if the project has strict WCAG requirements.",
    "neutral_scale": "Cool-neutral gray running from #FAFAFA (gray.50) to #222222 (gray.900). text-primary anchors at gray.900 per operator brief.",
    "state_colors": "Standard semantic palette (Tailwind/Radix family). Adjust if the project's brand library overrides."
  },
  "color": {
    "primitive": {
      "gray": {
        "50":  "#FAFAFA",
        "100": "#F4F4F5",
        "200": "#E4E4E7",
        "300": "#D4D4D8",
        "400": "#A1A1AA",
        "500": "#71717A",
        "600": "#52525B",
        "700": "#3F3F46",
        "800": "#2A2A2E",
        "900": "#222222"
      },
      "brand": {
        "_comment": "Primary scale anchored at brand.500 = #1c5d99 (operator-provided). brand.600 is the primary CTA tone; brand.700 is hover. brand.50/100 are tinted backgrounds and brand-subtle surfaces.",
        "50":  "#E6EEF5",
        "100": "#C5D6E7",
        "200": "#9DBAD2",
        "300": "#759DBC",
        "400": "#3F7DAE",
        "500": "#1c5d99",
        "600": "#154A7B",
        "700": "#10395F",
        "800": "#0B2945",
        "900": "#06182D"
      },
      "secondary": {
        "_comment": "Single anchor — accent-secondary = #639fab (operator-provided). Used for secondary CTAs, ghost buttons, inactive states. Tints/shades derived for hover/active states.",
        "100": "#E0EBEF",
        "300": "#9CC1CA",
        "500": "#639fab",
        "700": "#4A7E89",
        "900": "#2F5258"
      },
      "disabled": {
        "_comment": "Anchor — surface-disabled = #bbcde5 (operator-provided, brand-tinted blue-gray). Reserved exclusively for disabled-state surfaces.",
        "bg": "#bbcde5"
      },
      "red":    { "500": "#EF4444", "600": "#DC2626", "100": "#FEE2E2" },
      "green":  { "500": "#10B981", "600": "#059669", "100": "#D1FAE5" },
      "yellow": { "500": "#F59E0B", "600": "#D97706", "100": "#FEF3C7" },
      "blue":   { "500": "#3B82F6", "600": "#2563EB", "100": "#DBEAFE" }
    },
    "semantic": {
      "text-primary":         "{color.primitive.gray.900}",
      "text-secondary":       "{color.primitive.gray.600}",
      "text-tertiary":        "{color.primitive.gray.500}",
      "text-disabled":        "{color.primitive.gray.400}",
      "text-on-brand":        "#FFFFFF",
      "text-on-secondary":    "#FFFFFF",
      "text-on-error":        "#FFFFFF",
      "text-link":            "{color.primitive.brand.600}",
      "text-link-hover":      "{color.primitive.brand.700}",
      "surface-default":      "#FFFFFF",
      "surface-subtle":       "{color.primitive.gray.50}",
      "surface-elevated":     "#FFFFFF",
      "surface-disabled":     "{color.primitive.disabled.bg}",
      "surface-brand":        "{color.primitive.brand.600}",
      "surface-brand-hover":  "{color.primitive.brand.700}",
      "surface-brand-subtle": "{color.primitive.brand.50}",
      "surface-secondary":    "{color.primitive.secondary.500}",
      "surface-secondary-hover": "{color.primitive.secondary.700}",
      "surface-secondary-subtle": "{color.primitive.secondary.100}",
      "border-default":       "{color.primitive.gray.200}",
      "border-strong":        "{color.primitive.gray.300}",
      "border-focus":         "{color.primitive.brand.500}",
      "accent-brand":         "{color.primitive.brand.500}",
      "accent-brand-hover":   "{color.primitive.brand.600}",
      "accent-brand-active":  "{color.primitive.brand.700}",
      "accent-brand-subtle":  "{color.primitive.brand.50}",
      "accent-secondary":     "{color.primitive.secondary.500}",
      "accent-secondary-hover": "{color.primitive.secondary.700}",
      "accent-secondary-subtle": "{color.primitive.secondary.100}",
      "state-error":          "{color.primitive.red.500}",
      "state-error-bg":       "{color.primitive.red.100}",
      "state-success":        "{color.primitive.green.500}",
      "state-success-bg":     "{color.primitive.green.100}",
      "state-warning":        "{color.primitive.yellow.500}",
      "state-warning-bg":     "{color.primitive.yellow.100}",
      "state-info":           "{color.primitive.blue.500}",
      "state-info-bg":        "{color.primitive.blue.100}"
    }
  },
  "spacing": {
    "scale": "4pt",
    "space-0": 0, "space-1": 4, "space-2": 8, "space-3": 12, "space-4": 16,
    "space-5": 24, "space-6": 32, "space-7": 48, "space-8": 64
  },
  "radius": {
    "none": 0, "sm": 4, "md": 8, "lg": 12, "full": 9999,
    "table-row": 0,
    "card":     8,
    "button":   8,
    "input":    8,
    "modal":    12,
    "pill":     9999
  },
  "elevation": {
    "none": "none",
    "sm":   "0 1px 2px rgba(0,0,0,0.06)",
    "md":   "0 3px 8px rgba(0,0,0,0.08)",
    "lg":   "0 8px 24px rgba(0,0,0,0.10)",
    "xl":   "0 16px 48px rgba(0,0,0,0.12)"
  },
  "motion": {
    "instant": "0ms",
    "fast":    "150ms",
    "default": "250ms",
    "slow":    "400ms"
  },
  "z-index": {
    "base":     0,
    "dropdown": 100,
    "sticky":   200,
    "modal":    1000,
    "toast":    2000
  }
}
